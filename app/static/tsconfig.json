{
  "compilerOptions": {
    "target": "ES2022",
    "module": "none",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true
  },
  "files": [
    "ts/simulation-contracts.ts",
    "ts/model-data.ts",
    "ts/simulation-provider.ts"
  ]
}
